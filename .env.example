# GEMINI_API_KEY: Mandatory API key for Gemini chat, search grounding, and instructions
GEMINI_API_KEY=

# APP_URL: Base URL where this applet is hosted
APP_URL=http://localhost:3000

# VITE_API_BASE_URL: Backend service API host URL (leave empty in standard Cloud Run deploys)
VITE_API_BASE_URL=

# FIREBASE_SERVICE_ACCOUNT_KEY: Optional. Service Account private key JSON (minimized single-line string)
# to authorize administrative writes and reads to Cloud Firestore from the Node.js backend.
# If omitted or invalid, the workspace gracefully falls back to clean, high-fidelity in-memory storage.
FIREBASE_SERVICE_ACCOUNT_KEY=

# GOOGLE_CLIENT_ID: Optional. Google OAuth Client ID for authenticating users in the Hub.
GOOGLE_CLIENT_ID=

# GOOGLE_CLIENT_SECRET: Optional. Google OAuth Client Secret for authenticating users in the Hub.
GOOGLE_CLIENT_SECRET=
